{{>layouts/header}}
{{>layouts/nav}}

<div class="container mt-4">
  <h2 class="mb-3">꿀팁 게시판</h2>

  <form action="/tipSearch" method="get" class="mb-3">
    <div class="input-group">
      <select name="name" class="form-select">
        <option value="subject">제목</option>
        <option value="content">내용</option>
        <option value="nicname">닉네임</option>
        <option value="category">아이디</option>
        <option value="subjcont">제목+내용</option>
      </select>
      <input type="text" name="keyword" class="form-control" placeholder="검색어 입력">
      <button class="btn btn-dark" type="submit">검색</button>
    </div>
  </form>

  <div class="text-end mb-3">
    {{#member}}
    <a href="/board/tipBoardWriteForm" class="btn btn-outline-primary">글쓰기</a>
    {{/member}}
  </div>

  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th>번호</th>
        <th>제목</th>
        <th>닉네임</th>
        <th>조회수</th>
        <th>추천수</th>
        <th>작성일</th>
      </tr>
    </thead>
    <tbody>
      {{#page.content}}
      <tr>
        <td>{{board_num}}</td>
        <td><a href="/board/tipBoardView?board_num={{board_num}}&pg={{currentPage}}">{{board_title}}</a></td>
        <td>{{nick_name}}</td>
        <td>{{board_hit}}</td>
        <td>{{recommend}}</td>
        <td>{{#board_logtime}}{{.}}{{/board_logtime}}</td>
      </tr>
      {{/page.content}}
    </tbody>
  </table>

  <nav aria-label="Page navigation" class="d-flex justify-content-center">
    <ul class="pagination">
      {{#previousPage}}<li class="page-item"><a class="page-link" href="?pg={{previousPage}}">이전</a></li>{{/previousPage}}
      {{#pageList}}
      <li class="page-item {{#current}}active{{/current}}">
        <a class="page-link" href="?pg={{page}}">{{page}}</a>
      </li>
      {{/pageList}}
      {{#nextPage}}<li class="page-item"><a class="page-link" href="?pg={{nextPage}}">다음</a></li>{{/nextPage}}
    </ul>
  </nav>
</div>

{{>layouts/footer}}
