{{>layouts/header}}
{{>layouts/nav}}

<div class="container mt-4">
  <h2>게시글 상세 보기</h2>

  <table class="table table-bordered">
    <tbody>
      <tr><th>제목</th><td>{{board.board_title}}</td></tr>
      <tr><th>작성자</th><td>{{board.nick_name}}</td></tr>
      <tr><th>조회수</th><td>{{board.board_hit}}</td></tr>
      <tr><th>추천수</th><td>{{board.recommend}}</td></tr>
      <tr><th>작성일</th><td>{{board.board_logtime}}</td></tr>
      <tr>
        <td colspan="2">{{board.board_content}}</td>
      </tr>
      {{#board.board_img}}
      <tr><td colspan="2"><img src="/storage/{{board.board_img}}" class="img-fluid"/></td></tr>
      {{/board.board_img}}
    </tbody>
  </table>

  <div class="mb-3">
    <form method="post" action="/recommend">
      <input type="hidden" name="board_num" value="{{board.board_num}}">
      <button class="btn btn-outline-success" type="submit">추천</button>
    </form>
    <form method="post" action="/report" class="d-inline-block ms-2">
      <input type="hidden" name="board_num" value="{{board.board_num}}">
      <button class="btn btn-outline-danger" type="submit">신고</button>
    </form>
  </div>

  {{#isMemId}}
  <div class="mb-3">
    <a href="/board/tipBoardModifyForm?board_num={{board.board_num}}&pg={{pg}}" class="btn btn-warning">수정</a>
    <a href="/board/tipBoardDelete?board_num={{board.board_num}}&pg={{pg}}" class="btn btn-danger">삭제</a>
  </div>
  {{/isMemId}}

  <a href="/board/tipBoardList?pg={{pg}}" class="btn btn-secondary">목록</a>
</div>

{{>layouts/footer}}
